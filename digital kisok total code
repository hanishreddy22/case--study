# ===== CURRENCY EXCHANGE =====
def currency_exchange():
"""Currency exchange calculator"""
clear_screen()
print_header("CURRENCY EXCHANGE CALCULATOR")
print("\nAvailable Currencies and Exchange Rates:")
print("-" * 60)
currencies = list(exchange_rates.keys())
for idx, curr in enumerate(currencies, 1):
print(f"{idx}. {curr} (Base Rate: 1 {curr} = {exchange_rates[curr]} INR)")
print("\n" + "-" * 60)
from_curr = input("\nWhat currency are you converting FROM? (e.g., USD): ").strip().upper
if from_curr not in exchange_rates:
print("\nSorry, that currency is not available in our system.")
time.sleep(1.5)
return
to_curr = input("What currency are you converting TO? (e.g., INR): ").strip().upper()
if to_curr not in exchange_rates:
print("\nSorry, that currency is not available in our system.")
time.sleep(1.5)
return
try:
amount = float(input(f"\nEnter the amount in {from_curr}: "))
if amount < 0:
print("\nSorry, the amount cannot be negative.")
time.sleep(1.5)
return
except ValueError:
print("\nSorry, that is not a valid amount. Please enter a number.")
time.sleep(1.5)
return
# Convert to INR first, then to target currency
amount_in_inr = amount * exchange_rates[from_curr]
amount_in_target = amount_in_inr / exchange_rates[to_curr]
clear_screen()
print_header("CURRENCY CONVERSION RESULT")
exchange_rate = exchange_rates[to_curr] / exchange_rates[from_curr]
print(f"\nExchange Rate: 1 {from_curr} = {exchange_rate:.4f} {to_curr}")
print("\n" + "-" * 60)
print(f"Original Amount: {amount:.2f} {from_curr}")
print(f"Converted Amount: {amount_in_target:.2f} {to_curr}")
print(f"Transaction Fee (2%): {amount_in_target * 0.02:.2f} {to_curr}")
print(f"Final Amount After Fee: {amount_in_target * 0.98:.2f} {to_curr}")
print("-" * 60)
input("\nPress Enter to return to main menu...")
